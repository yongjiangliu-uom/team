########################################
# Python
########################################
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.ruff_cache/
.ipynb_checkpoints/

########################################
# Virtualenv / Environment
########################################
.venv/
venv/
ENV/
.env
.env.*
!.env.example

########################################
# Flask / Local runtime files
########################################
instance/
*.sqlite3
*.db

########################################
# macOS / Windows
########################################
.DS_Store
Thumbs.db

########################################
# IDE / Editor
########################################
.idea/
*.iml
.vscode/
*.swp
*.swo

########################################
# Logs
########################################
*.log

