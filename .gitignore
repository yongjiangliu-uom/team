########################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

########################################
# Project-specific: ignore backend-generated junk anywhere
########################################
backend/**/__pycache__/
backend/**/*.pyc
backend/.venv/
backend/venv/
backend/instance/
backend/*.sqlite3
backend/*.db
backend/.env
backend/.env.*